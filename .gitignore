*.token

# Decrypted age private key — must never be committed. The wrapped versions
# (age-identity.txt.age and age-identity.txt.kms) are safe to commit.
config/age-identity.txt

# Terraform local artifacts. State lives in ORM (see terraform/README.md);
# scripts/tf-env.sh materializes a backend_override.tf pointing at a cached
# pull of that state for fast local plans — never commit it.
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfplan
terraform/crash.log
terraform/crash.*.log
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json
