*.token

# Decrypted age private key — must never be committed. The wrapped versions
# (age-identity.txt.age and age-identity.txt.kms) are safe to commit.
config/age-identity.txt

# Terraform local artifacts. State lives in ORM (see terraform/README.md);
# scripts/tf-env.sh pulls a snapshot into .tfstate-cache/ for fast local plans.
# The backend_override.tf is committed as backend_override.tf.local and renamed
# in/out by scripts/tf-env{,-off}.sh — neither form is gitignored, so a
# forgotten rename shows up in `git status` instead of going silently missing.
terraform/.terraform/
terraform/.tfstate-cache/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfplan
terraform/crash.log
terraform/crash.*.log

# Helm dependencies are fetched from Chart.lock during rendering.
cilium/charts/
