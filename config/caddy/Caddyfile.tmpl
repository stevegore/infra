{
	email steve.j.gore@gmail.com

	servers :443 {
		name stevegore
		protocols h1 h2 h2c h3
		strict_sni_host on
	}

	log default {
		output file /var/lib/caddy/caddy.log
		format json
		exclude http.log.access
		level INFO
	}

	order authenticate before respond
	order authorize before basicauth

	# github.com/greenpau/caddy-security
	security {
		oauth identity provider github {env.GITHUB_CLIENT_ID} {env.GITHUB_CLIENT_SECRET}

		authentication portal stevegoreauthportal {
			crypto default token lifetime 3600
			crypto key sign-verify from file /etc/caddy/keys/jwt-private.pem
			cookie domain stevegore.au
			enable identity provider github
			ui {
				links {
					"My Identity" "/whoami" icon "las la-user"
				}
			}

			transform user {
				match realm github
				match sub github.com/stevegore
				action add role authp/admin
			}
		}

		authorization policy adminonly {
			set auth url https://auth.stevegore.au/oauth2/github
			crypto key verify from file /etc/caddy/keys/jwt-public.pem
			allow roles authp/admin authp/user
			validate bearer header
			inject headers with claims
		}

		authorization policy vaultaccess {
			set auth url https://auth.stevegore.au/oauth2/github
			crypto key verify from file /etc/caddy/keys/jwt-public.pem
			allow roles authp/admin authp/user
			validate bearer header
			inject headers with claims
		}
	}
}

(defaults) {
	encode gzip
}

auth.stevegore.au {
	authenticate with stevegoreauthportal
}

hass.stevegore.au {
	reverse_proxy 10.20.30.1:8123
	import defaults
}

desk.stevegore.au {
	authorize with adminonly
	reverse_proxy 10.20.30.1:8111
	import defaults
}

gym.stevegore.au {
	authorize with adminonly
	reverse_proxy 10.20.30.1:8112
	import defaults
}

plex.stevegore.au {
