bw.stevegore.au {
	header / {
		Strict-Transport-Security "max-age=31536000;"
		X-XSS-Protection "1; mode=block"
		X-Frame-Options "DENY"
		X-Robots-Tag "none"
		-Server
	}
	reverse_proxy /notifications/hub/negotiate 10.20.30.1:8081
	reverse_proxy /notifications/hub 10.20.30.1:3012
	reverse_proxy 10.20.30.1:8081 {
		header_up X-Real-IP {remote_host}
	}
	import defaults
}

strava.stevegore.au {
	reverse_proxy 10.20.30.1:8180
}

healthz.stevegore.au {
	respond "OK"
}

argocd.stevegore.au {
	reverse_proxy https://127.0.0.1:32392 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

grpc.argocd.stevegore.au {
	reverse_proxy h2c://127.0.0.1:30481
}

stevegore.au {
	respond /health "I'm doing ok, thanks for asking :)"
	respond /healthz "I'm doing ok, thanks for asking :)"
	reverse_proxy 10.20.30.1:8788
}

localhost {
	respond "Yep, it's working"
}

