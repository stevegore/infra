# Plaintext schema of `secrets.sops.yaml` BEFORE encryption.
# To create the real encrypted file:
#
#   cp config/secrets.sops.yaml.example config/secrets.sops.yaml
#   # ...fill in real values...
#   sops -e -i config/secrets.sops.yaml
#
# To edit later: `sops config/secrets.sops.yaml` (decrypts → editor → re-encrypts).
#
# Naming: scalar keys here become UPPER_SNAKE_CASE env vars during template
# render (e.g. github_client_secret → ${GITHUB_CLIENT_SECRET}).
# Multi-line values (PEM blocks) are written directly to files by name.

# --- Caddy / GitHub OAuth ---
github_client_id: REPLACE_ME              # caddy-security OAuth app client ID
github_client_secret: REPLACE_ME          # caddy-security OAuth app secret
jwt_shared_key: REPLACE_ME                # legacy HMAC key — kept for caddy.env compatibility

# --- WireGuard (10.20.30.2 hub) ---
wireguard_private_key: REPLACE_ME         # base64; matches /etc/wireguard/wg0.conf [Interface]
wireguard_peer_pico_pubkey: REPLACE_ME    # pico's WG public key
wireguard_peer_laptop_pubkey: REPLACE_ME  # laptop's WG public key

# --- Caddy JWT signing key (RSA) ---
# Written verbatim to /etc/caddy/keys/jwt-private.pem (mode 600, caddy:caddy).
jwt_private_key: |
  -----BEGIN PRIVATE KEY-----
  REPLACE_ME
  -----END PRIVATE KEY-----
